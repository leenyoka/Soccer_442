<?xml version="1.0" encoding="utf-8"?>
<!-- Generic team badge shown instead of a crest when a fixture's participant isn't
     determined yet (e.g. World Cup "Quarterfinal 1 Winner"). Rectangular (not a circle)
     to match this competition's real crests, which are national flags - the ImageView's
     default fitCenter scaleType letterboxes this the same way it does real flag images.
     Styled like the app's existing buttons/panels (dark green gradient, cream stroke) so
     it reads as an intentional placeholder badge rather than a missing/broken image. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#004a00"
        android:centerColor="#006000"
        android:endColor="#003000"
        android:angle="270" />
    <stroke android:width="2dp" android:color="#FBF5EF" />
    <corners android:radius="2dp" />
    <size android:width="90dp" android:height="60dp" />
</shape>
